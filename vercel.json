{
  "rewrites": [
    {
      "source": "/api/:path",
      "destination": "https://zyntra.dpdns.org/api/auth/callback"
    },
    {
      "source": "/transcripts/:path*",
      "destination": "https://zyntra.dpdns.org/transcripts/:path"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
